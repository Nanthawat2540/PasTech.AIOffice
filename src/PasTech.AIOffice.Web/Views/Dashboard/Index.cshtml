@model List<PasTech.AIOffice.Domain.Entities.OfficeTask>
@{
    ViewData["Title"] = "Dashboard";
    var statusColor = new Dictionary<PasTech.AIOffice.Domain.Enums.OfficeTaskStatus, string> {
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Inquiry]      = "secondary",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Survey]        = "info",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Quotation]     = "warning",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.PO]            = "primary",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Installation]  = "primary",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Handover]      = "success",
        [PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Closed]        = "dark",
    };
    var totalTasks   = Model.Count;
    var activeTasks  = Model.Count(t => t.Status != PasTech.AIOffice.Domain.Enums.OfficeTaskStatus.Closed);
    var pipeline     = Model.Where(t => t.QuotationAmount.HasValue).Sum(t => t.QuotationAmount!.Value);
    var agentRuns    = Model.Sum(t => t.Logs.Count);
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <h4 class="mb-1 fw-bold" style="font-family:var(--font-mono);color:#58a6ff">
            <i class="bi bi-grid-1x2-fill me-2"></i>AI Officer Dashboard
        </h4>
        <small class="text-muted">PasTech System Co., Ltd. — Real-time AI Agent Monitor</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-success px-3 py-2" style="font-family:var(--font-mono);font-size:.7rem" id="clock">--:--:--</span>
        <a asp-action="NewTask" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-lg me-1"></i>งานใหม่
        </a>
    </div>
</div>

<!-- Agent Pills -->
<div class="row g-2 mb-4">
    @foreach (var agent in new[] {
        ("Sales","bi-briefcase-fill","#58a6ff"),
        ("Survey","bi-search","#a78bfa"),
        ("Quotation","bi-file-earmark-text","#d29922"),
        ("Project","bi-kanban","#3fb950"),
        ("Document","bi-file-earmark-check","#58a6ff"),
        ("Support","bi-tools","#f85149"),
        ("Marketing","bi-megaphone","#e87316")
    })
    {
        <div class="col" data-aos="fade-up" data-aos-delay="@(Array.IndexOf(new[]{"Sales","Survey","Quotation","Project","Document","Support","Marketing"}, agent.Item1) * 50)">
            <div class="card text-center p-2" style="border-color:#21262d;background:#161b22;cursor:default"
                 onmouseenter="this.style.borderColor='@agent.Item3'" onmouseleave="this.style.borderColor='#21262d'">
                <i class="bi @agent.Item2 mb-1" style="color:@agent.Item3;font-size:1.3rem"></i>
                <div style="font-size:.7rem;color:#8b949e;font-weight:600;letter-spacing:.5px">@agent.Item1.ToUpper()</div>
                <div class="mt-1">
                    <span class="badge" style="background:rgba(63,185,80,.12);color:#3fb950;font-size:.6rem;letter-spacing:1px">IDLE</span>
                </div>
            </div>
        </div>
    }
</div>

<!-- Stat Cards + Chart -->
<div class="row g-3 mb-4">
    <div class="col-md-3" data-aos="fade-up" data-aos-delay="0">
        <div class="card p-3" style="border-color:#21262d;background:#161b22">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted mb-1" style="font-size:.7rem;letter-spacing:1px">TOTAL TASKS</div>
                    <div class="fw-bold" style="font-size:2rem;font-family:var(--font-mono);color:#58a6ff" id="cnt-total">0</div>
                </div>
                <i class="bi bi-folder2-open" style="font-size:1.8rem;color:#21262d"></i>
            </div>
            <div class="mt-2" style="height:40px"><canvas id="chart-total"></canvas></div>
        </div>
    </div>
    <div class="col-md-3" data-aos="fade-up" data-aos-delay="80">
        <div class="card p-3" style="border-color:#21262d;background:#161b22">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted mb-1" style="font-size:.7rem;letter-spacing:1px">ACTIVE</div>
                    <div class="fw-bold" style="font-size:2rem;font-family:var(--font-mono);color:#3fb950" id="cnt-active">0</div>
                </div>
                <i class="bi bi-activity" style="font-size:1.8rem;color:#21262d"></i>
            </div>
            <div class="mt-2" style="height:40px"><canvas id="chart-active"></canvas></div>
        </div>
    </div>
    <div class="col-md-3" data-aos="fade-up" data-aos-delay="160">
        <div class="card p-3" style="border-color:#21262d;background:#161b22">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted mb-1" style="font-size:.7rem;letter-spacing:1px">PIPELINE (฿)</div>
                    <div class="fw-bold" style="font-size:1.5rem;font-family:var(--font-mono);color:#d29922" id="cnt-pipeline">0</div>
                </div>
                <i class="bi bi-graph-up-arrow" style="font-size:1.8rem;color:#21262d"></i>
            </div>
            <div class="mt-2" style="height:40px"><canvas id="chart-pipeline"></canvas></div>
        </div>
    </div>
    <div class="col-md-3" data-aos="fade-up" data-aos-delay="240">
        <div class="card p-3" style="border-color:#21262d;background:#161b22">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="text-muted mb-1" style="font-size:.7rem;letter-spacing:1px">AGENT RUNS</div>
                    <div class="fw-bold" style="font-size:2rem;font-family:var(--font-mono);color:#a78bfa" id="cnt-runs">0</div>
                </div>
                <i class="bi bi-robot" style="font-size:1.8rem;color:#21262d"></i>
            </div>
            <div class="mt-2" style="height:40px"><canvas id="chart-runs"></canvas></div>
        </div>
    </div>
</div>

<!-- Task Table -->
<div class="card" style="border-color:#21262d;background:#161b22" data-aos="fade-up" data-aos-delay="100">
    <div class="card-header d-flex justify-content-between align-items-center" style="border-color:#21262d;background:rgba(255,255,255,.03)">
        <span class="fw-semibold"><i class="bi bi-table me-2 text-primary"></i>งานทั้งหมด</span>
        <span class="badge bg-secondary">@totalTasks รายการ</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-robot" style="font-size:3rem;opacity:.3"></i>
                <p class="mt-2">ยังไม่มีงาน — <a asp-action="NewTask" class="text-primary">เพิ่มงานแรก</a></p>
            </div>
        }
        else
        {
            <table id="taskTable" class="table table-hover mb-0" style="color:#e6edf3">
                <thead>
                    <tr style="border-color:#21262d">
                        <th>Task#</th>
                        <th>ลูกค้า</th>
                        <th>ประเภท</th>
                        <th>Status</th>
                        <th>มูลค่า (฿)</th>
                        <th>Agent Runs</th>
                        <th>วันที่</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr style="border-color:#21262d">
                            <td><span class="mono" style="color:#58a6ff;font-size:.85rem">@t.TaskNumber</span></td>
                            <td class="fw-semibold">@t.CustomerName</td>
                            <td><span class="badge bg-secondary">@t.JobType</span></td>
                            <td><span class="badge bg-@statusColor[t.Status]">@t.Status</span></td>
                            <td class="mono">@(t.QuotationAmount.HasValue ? t.QuotationAmount.Value.ToString("N0") : "—")</td>
                            <td>
                                <span class="badge" style="background:rgba(167,139,250,.15);color:#a78bfa">
                                    <i class="bi bi-robot me-1"></i>@t.Logs.Count
                                </span>
                            </td>
                            <td style="color:#8b949e;font-size:.85rem">@t.CreatedAt.ToString("dd/MM/yy")</td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@t.Id"
                                   class="btn btn-sm btn-outline-primary px-3">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script>
// CountUp
const opts = { duration: 1.5, separator: ',' };
new countUp.CountUp('cnt-total',   @totalTasks,  opts).start();
new countUp.CountUp('cnt-active',  @activeTasks, opts).start();
new countUp.CountUp('cnt-pipeline',@pipeline,    {...opts, prefix:'฿'}).start();
new countUp.CountUp('cnt-runs',    @agentRuns,   opts).start();

// Sparkline helper
function sparkline(id, data, color) {
    const ctx = document.getElementById(id);
    if (!ctx || !data.length) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: data.map((_,i) => i),
            datasets: [{ data, borderColor: color, borderWidth: 2, tension: .4,
                fill: true,
                backgroundColor: color.replace(')',', 0.08)').replace('rgb','rgba'),
                pointRadius: 0 }]
        },
        options: { plugins:{legend:{display:false}}, scales:{x:{display:false},y:{display:false}}, animation:{duration:1200} }
    });
}
// Demo sparklines (ใช้ค่าสุ่มจำลอง trend)
sparkline('chart-total',    [2,3,3,5,4,6,@totalTasks],  'rgb(88,166,255)');
sparkline('chart-active',   [1,2,2,3,3,4,@activeTasks], 'rgb(63,185,80)');
sparkline('chart-pipeline', [0,1,2,3,4,5,@(pipeline > 0 ? 6 : 0)], 'rgb(210,153,34)');
sparkline('chart-runs',     [0,1,3,4,5,6,@agentRuns],   'rgb(167,139,250)');

// DataTable
@if (Model.Any())
{
    <text>
    $('#taskTable').DataTable({
        order: [[6, 'desc']],
        pageLength: 15,
        language: {
            search: '', searchPlaceholder: '🔍 ค้นหา...',
            lengthMenu: 'แสดง _MENU_ รายการ',
            info: 'รายการ _START_–_END_ จาก _TOTAL_',
            paginate: { previous: '‹', next: '›' },
            zeroRecords: 'ไม่พบข้อมูล', emptyTable: 'ยังไม่มีงาน'
        },
        columnDefs: [{ orderable: false, targets: 7 }]
    });
    </text>
}

// Clock
function tick() {
    const el = document.getElementById('clock');
    if (el) el.textContent = new Date().toLocaleTimeString('th-TH', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick, 1000);
</script>
}
