@model PasTech.AIOffice.Domain.Entities.OfficeTask
@{
    ViewData["Title"] = Model.TaskNumber;
    var agents = new[] {
        (PasTech.AIOffice.Domain.Enums.AgentType.Sales,        "💼 Sales Agent",         "bi-briefcase",    "#58a6ff", "พิมพ์ inquiry หรือข้อความลูกค้า..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.SurveyDesign, "🔍 Survey & Design",     "bi-search",       "#a78bfa", "ระบุข้อมูลหน้างาน: พื้นที่, จุดติดตั้ง, ระบบเดิม..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.Quotation,    "📋 Quotation Agent",     "bi-file-earmark", "#d29922", "วาง BOM จาก Survey & Design Agent..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.Project,      "📅 Project Agent",       "bi-kanban",       "#3fb950", "วาง Quotation ที่อนุมัติแล้ว + วันเริ่มงาน..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.Document,     "📄 Document Agent",      "bi-file-check",   "#58a6ff", "ระบุอุปกรณ์ที่ติดตั้งจริง, serial number..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.Support,      "🛠️ Support Agent",       "bi-tools",        "#f85149", "อธิบายอาการที่ลูกค้าแจ้ง..."),
        (PasTech.AIOffice.Domain.Enums.AgentType.Marketing,    "📣 Marketing Agent",     "bi-megaphone",    "#e87316", "สรุปงานที่เสร็จแล้ว รูปภาพ/ข้อมูลที่มี..."),
    };
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
        <h4 class="mb-0 fw-bold" style="font-family:var(--font-mono);color:#58a6ff">
            @Model.TaskNumber
            <span style="color:#e6edf3;font-size:1rem;font-weight:500">— @Model.CustomerName</span>
        </h4>
        <div class="mt-1">
            <span class="badge bg-secondary me-1">@Model.JobType</span>
            <span class="badge bg-primary">@Model.Status</span>
        </div>
    </div>
    @if (Model.QuotationAmount.HasValue)
    {
        <div class="text-end" data-aos="fade-left">
            <div class="fw-bold" style="font-size:1.8rem;color:#3fb950;font-family:var(--font-mono)">
                ฿<span id="quote-amount">0</span>
            </div>
            <small class="text-muted mono">@Model.QuotationNumber</small>
        </div>
    }
</div>

<div class="row g-4">
    <!-- Left: Info + Agent Runner -->
    <div class="col-md-5">
        <!-- Task Info -->
        <div class="card mb-3" style="border-color:#21262d;background:#161b22" data-aos="fade-right">
            <div class="card-header" style="border-color:#21262d;background:rgba(255,255,255,.03)">
                <i class="bi bi-pin-map text-primary me-2"></i><strong>ข้อมูลงาน</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0" style="color:#e6edf3">
                    <tr style="border-color:#21262d">
                        <td class="text-muted ps-3" style="width:30%">ลูกค้า</td>
                        <td class="fw-semibold">@Model.CustomerName</td>
                    </tr>
                    <tr style="border-color:#21262d">
                        <td class="text-muted ps-3">Email</td>
                        <td>@(Model.CustomerEmail ?? "—")</td>
                    </tr>
                    <tr style="border-color:#21262d">
                        <td class="text-muted ps-3">โทร</td>
                        <td>@(Model.CustomerPhone ?? "—")</td>
                    </tr>
                    <tr style="border-color:#21262d">
                        <td class="text-muted ps-3">สถานที่</td>
                        <td>@(Model.Location ?? "—")</td>
                    </tr>
                    <tr style="border-color:#21262d">
                        <td class="text-muted ps-3">วันที่</td>
                        <td class="mono" style="font-size:.85rem">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                </table>
                <div class="p-3 border-top" style="border-color:#21262d!important">
                    <div class="text-muted mb-1" style="font-size:.8rem;font-weight:600;letter-spacing:.5px">INQUIRY</div>
                    <p class="mb-0" style="font-size:.9rem;line-height:1.6">@Model.Description</p>
                </div>
            </div>
        </div>

        <!-- Run Agent -->
        <div class="card" style="border-color:#21262d;background:#161b22" data-aos="fade-right" data-aos-delay="80">
            <div class="card-header" style="border-color:#21262d;background:rgba(255,255,255,.03)">
                <i class="bi bi-robot text-primary me-2"></i><strong>เรียกใช้ Agent</strong>
            </div>
            <div class="card-body">
                <form asp-action="RunAgent" method="post" id="agentForm">
                    <input type="hidden" name="taskId" value="@Model.Id" />
                    <input type="hidden" name="provider" id="providerInput" value="claude" />

                    <!-- Model Selector -->
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:.75rem;letter-spacing:.5px">AI MODEL</label>
                        <div class="d-flex gap-2">
                            <div class="model-btn active" data-val="claude" onclick="selectModel(this)">
                                <i class="bi bi-cpu me-1"></i>Claude
                                <small style="display:block;font-size:.6rem;opacity:.6;font-family:var(--font-mono)">sonnet-4-6</small>
                            </div>
                            <div class="model-btn" data-val="gemini" onclick="selectModel(this)">
                                <i class="bi bi-stars me-1"></i>Gemini
                                <small style="display:block;font-size:.6rem;opacity:.6;font-family:var(--font-mono)">1.5-pro</small>
                            </div>
                        </div>
                    </div>

                    <!-- Agent Selector -->
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:.75rem;letter-spacing:.5px">AGENT</label>
                        <select name="agentType" class="form-select" id="agentSelect" style="font-size:.9rem">
                            @foreach (var a in agents)
                            {
                                <option value="@a.Item1" data-hint="@a.Item5" data-color="@a.Item4">@a.Item2</option>
                            }
                        </select>
                    </div>

                    <!-- Input -->
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size:.75rem;letter-spacing:.5px">INPUT</label>
                        <textarea name="input" id="agentInput" class="form-control" rows="5"
                                  style="font-size:.875rem;font-family:var(--font-mono);resize:vertical"
                                  placeholder="@agents[0].Item5"></textarea>
                    </div>

                    <button type="button" class="btn btn-primary w-100" id="runBtn" onclick="confirmRun()">
                        <i class="bi bi-play-fill me-2"></i>Run Agent
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right: Logs -->
    <div class="col-md-7">
        <div class="card" style="border-color:#21262d;background:#161b22" data-aos="fade-left">
            <div class="card-header d-flex justify-content-between align-items-center" style="border-color:#21262d;background:rgba(255,255,255,.03)">
                <span><i class="bi bi-terminal text-primary me-2"></i><strong>Agent Logs</strong></span>
                <span class="badge" style="background:rgba(167,139,250,.15);color:#a78bfa">
                    <i class="bi bi-robot me-1"></i>@Model.Logs.Count runs
                </span>
            </div>
            <div class="card-body p-0" style="max-height:72vh;overflow-y:auto" id="logContainer">
                @if (!Model.Logs.Any())
                {
                    <div class="text-center py-5 text-muted" id="emptyLogs">
                        <i class="bi bi-terminal" style="font-size:2.5rem;opacity:.3"></i>
                        <p class="mt-2 mb-0" style="font-size:.9rem">ยังไม่มี log — เรียกใช้ Agent ได้เลย</p>
                    </div>
                }
                @foreach (var log in Model.Logs.OrderByDescending(l => l.CreatedAt))
                {
                    var provMatch = System.Text.RegularExpressions.Regex.Match(log.Action, @"\[(\w+)\]");
                    var provLabel = provMatch.Success ? provMatch.Groups[1].Value : "Claude";
                    var provColor = provLabel.ToLower() == "gemini" ? "#3fb950" : "#a78bfa";
                    <div class="p-3 border-bottom" style="border-color:#21262d!important">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-primary">@log.Agent</span>
                                <span class="badge" style="background:rgba(88,166,255,.08);color:@provColor;font-size:.65rem;font-family:var(--font-mono)">
                                    @provLabel
                                </span>
                            </div>
                            <small class="text-muted mono" style="font-size:.75rem">
                                @log.CreatedAt.ToString("dd/MM HH:mm")
                                <span class="ms-2 badge bg-secondary">@log.TokensUsed tok</span>
                            </small>
                        </div>
                        <div class="p-3 rounded" style="background:rgba(0,0,0,.3);border:1px solid #21262d;white-space:pre-wrap;font-size:.85rem;line-height:1.7;max-height:350px;overflow-y:auto;font-family:var(--font-mono)">@log.Output</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// CountUp for quotation
@if (Model.QuotationAmount.HasValue)
{
    <text>
    new countUp.CountUp('quote-amount', @Model.QuotationAmount.Value, { duration: 1.5, separator: ',' }).start();
    </text>
}

// Agent selector hint
document.getElementById('agentSelect').addEventListener('change', function() {
    const opt = this.options[this.selectedIndex];
    document.getElementById('agentInput').placeholder = opt.dataset.hint;
});

function selectModel(el) {
    document.querySelectorAll('.model-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('providerInput').value = el.dataset.val;
}

// SweetAlert2 confirm before run
function confirmRun() {
    const agent = document.getElementById('agentSelect');
    const agentName = agent.options[agent.selectedIndex].text;
    const provider = document.getElementById('providerInput').value;
    const input = document.getElementById('agentInput').value.trim();

    if (!input) {
        Swal.fire({
            icon: 'warning', title: 'กรุณาใส่ Input',
            text: 'ต้องมีข้อมูลก่อนส่งให้ Agent',
            background: '#161b22', color: '#e6edf3',
            confirmButtonColor: '#58a6ff', confirmButtonText: 'ตกลง'
        });
        return;
    }

    Swal.fire({
        title: `Run ${agentName}?`,
        html: `<div style="font-size:.85rem;color:#8b949e">
                 Model: <span style="color:#a78bfa;font-family:monospace">${provider}</span><br/>
                 Input: <em style="color:#e6edf3">${input.substring(0,80)}${input.length>80?'…':''}</em>
               </div>`,
        icon: 'question',
        background: '#161b22', color: '#e6edf3',
        showCancelButton: true,
        confirmButtonColor: '#238636', cancelButtonColor: '#30363d',
        confirmButtonText: '<i class="bi bi-play-fill"></i> Run!',
        cancelButtonText: 'ยกเลิก',
    }).then(result => {
        if (result.isConfirmed) {
            const btn = document.getElementById('runBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>AI กำลังประมวลผล...';
            Notiflix.Notify.info(`${agentName} กำลังทำงาน...`);
            NProgress.start();
            document.getElementById('agentForm').submit();
        }
    });
}
</script>
}
