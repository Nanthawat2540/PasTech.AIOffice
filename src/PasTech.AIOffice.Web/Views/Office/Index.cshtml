</div>

@section Scripts {
<script>
'use strict';

/* ── Clock ── */
const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
function tick() {
    const n = new Date();
    const pad = v => String(v).padStart(2,'0');
    document.getElementById('lTime').textContent = `${pad(n.getHours())}:${pad(n.getMinutes())}:${pad(n.getSeconds())}`;
    document.getElementById('lDate').textContent  = `DATE: ${pad(n.getDate())} ${MONTHS[n.getMonth()]} ${n.getFullYear()}`;
}
tick(); setInterval(tick,1000);

/* ── Canvas setup ── */
const canvas = document.getElementById('officeCanvas');
const ctx    = canvas.getContext('2d');
const wrap   = document.getElementById('canvasWrap');
const tip    = document.getElementById('cTip');

function resize() { canvas.width = wrap.clientWidth; canvas.height = wrap.clientHeight; }
resize();
window.addEventListener('resize', resize);

/* ── Sprite loading ── */
const GH = 'https://raw.githubusercontent.com/pixel-agents-hq/pixel-agents/main/webview-ui/public/assets';
const spr = { chars: new Array(6).fill(null), desk: null, plant: null };
let loaded = 0;
const TOTAL = 8;

function ldImg(src) {
    return new Promise(res => {
        const img = new Image(); img.crossOrigin = 'anonymous';
        img.onload  = () => { loaded++; pct(); res(img); };
        img.onerror = () => { loaded++; pct(); res(null); };
        img.src = src;
    });
}
function pct() { document.getElementById('loadFill').style.width = Math.min(100,Math.round(loaded/TOTAL*100))+'%'; }

async function boot() {
    document.getElementById('loadSub').textContent = 'Loading character sprites...';
    for (let i = 0; i < 6; i++) spr.chars[i] = await ldImg(`${GH}/char_${i}.png`);
    document.getElementById('loadSub').textContent = 'Loading furniture...';
    spr.desk  = await ldImg(`${GH}/DESK/DESK_FRONT.png`);
    spr.plant = await ldImg(`${GH}/PLANT/PLANT.png`);
    document.getElementById('loadOv').classList.add('gone');
    startLoop();
}
boot();

/* ── Floor / Room data ── */
const FLOORS = [
    { label:'COMMAND CENTER', isCmd:true, rooms:[
        { id:'cmd', name:'AI Director', eng:'AI Director', role:'System Coordinator', dept:'CMD', charIdx:0, accent:[240,192,64] }
    ]},
    { label:'F2 · OPERATIONS', rooms:[
        { id:'sales',     name:'สมหมาย', eng:'Sommai', role:'Sales Agent',     dept:'Sales',     charIdx:1, accent:[88,166,255]  },
        { id:'survey',    name:'วิท',    eng:'Wit',    role:'Survey & Design', dept:'Survey',    charIdx:2, accent:[34,211,238]  },
        { id:'quotation', name:'นาบ',    eng:'Nab',    role:'Quotation Agent', dept:'Quotation', charIdx:4, accent:[251,191,36]  },
    ]},
    { label:'F1 · PROJECTS', rooms:[
        { id:'project',  name:'พิม', eng:'Pim',   role:'Project Manager', dept:'Project',  charIdx:3, accent:[248,113,113] },
        { id:'document', name:'เอก', eng:'Ek',    role:'Technical Docs',  dept:'Document', charIdx:5, accent:[52,211,153]  },
        { id:'support',  name:'ช่วย', eng:'Chuai', role:'IT Support',     dept:'Support',  charIdx:0, accent:[251,146,60]  },
    ]},
    { label:'GND · GROUND', rooms:[
        { id:'server',    name:'Server Room', isServer:true, dept:'Server',    charIdx:-1, accent:[88,166,255]  },
        { id:'marketing', name:'มายา', eng:'Maya', role:'Marketing', dept:'Marketing', charIdx:2,  accent:[167,139,250] },
        { id:'lobby',     name:'Lobby', isLobby:true,         dept:'Lobby',     charIdx:5,  accent:[0,200,255]   },
    ]},
];

/* ── Stars ── */
const STARS = Array.from({length:80}, () => ({
    x: Math.random(), y: Math.random(), r: Math.random()*1.3+0.2, a: Math.random()*0.5+0.2
}));

/* ── Render loop ── */
let af = 0, roomHits = [];

function startLoop() {
    const FPS = 1000/20; let last = 0;
    (function loop(ts) {
        if (ts - last >= FPS) { last = ts; af = (af+1)%600; draw(); }
        requestAnimationFrame(loop);
    })(0);
}

/* ════════════════════════════════════
   MAIN DRAW
════════════════════════════════════ */
function draw() {
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0,0,W,H);
    roomHits = [];

    /* Background */
    ctx.fillStyle = '#030610'; ctx.fillRect(0,0,W,H);
    STARS.forEach(s => {
        const p = 0.6 + 0.4*Math.sin((af/600)*Math.PI*2 + s.x*12);
        ctx.beginPath(); ctx.arc(s.x*W, s.y*H, s.r, 0, Math.PI*2);
        ctx.fillStyle = `rgba(160,210,255,${s.a*p})`; ctx.fill();
    });

    /* Building geometry */
    const PX=14, PY=12;
    const bx=PX, by=PY, bw=W-PX*2, bh=H-PY-10;
    const avail = bh - 12; // subtract 3 × 4px separators
    const cmdH  = Math.floor(avail*0.31);
    const fh    = Math.floor(avail*0.22);
    const gndH  = avail - cmdH - fh*2;

    drawShell(bx, by, bw, bh);

    let cy = by + 2;
    drawCMD   (bx+2, cy, bw-4, cmdH);            cy += cmdH;
    drawSep   (bx+2, cy, bw-4);                   cy += 4;
    drawFRow  (bx+2, cy, bw-4, fh,   FLOORS[1]); cy += fh;
    drawSep   (bx+2, cy, bw-4);                   cy += 4;
    drawFRow  (bx+2, cy, bw-4, fh,   FLOORS[2]); cy += fh;
    drawSep   (bx+2, cy, bw-4);                   cy += 4;
    drawFRow  (bx+2, cy, bw-4, gndH, FLOORS[3]);
}

/* ── Building outer shell ── */
function drawShell(bx,by,bw,bh) {
    const r=7;
    ctx.beginPath();
    ctx.moveTo(bx+r,by); ctx.lineTo(bx+bw-r,by);
    ctx.quadraticCurveTo(bx+bw,by, bx+bw,by+r);
    ctx.lineTo(bx+bw,by+bh); ctx.lineTo(bx,by+bh); ctx.lineTo(bx,by+r);
    ctx.quadraticCurveTo(bx,by, bx+r,by);
    ctx.closePath();
    const g=ctx.createLinearGradient(bx,by,bx,by+bh);
    g.addColorStop(0,'#061424'); g.addColorStop(1,'#040c16');
    ctx.fillStyle=g; ctx.fill();
    ctx.save();
    ctx.shadowColor='rgba(0,100,255,0.5)'; ctx.shadowBlur=22;
    ctx.strokeStyle='rgba(0,110,255,0.65)'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.restore();
    /* depth strips */
    const dl=ctx.createLinearGradient(bx,by,bx+14,by);
    dl.addColorStop(0,'rgba(0,0,20,0.5)'); dl.addColorStop(1,'transparent');
    ctx.fillStyle=dl; ctx.fillRect(bx,by,14,bh);
    const dr=ctx.createLinearGradient(bx+bw-14,by,bx+bw,by);
    dr.addColorStop(0,'transparent'); dr.addColorStop(1,'rgba(0,0,20,0.5)');
    ctx.fillStyle=dr; ctx.fillRect(bx+bw-14,by,14,bh);
}

/* ── Floor separator ── */
function drawSep(fx,fy,fw) {
    const g=ctx.createLinearGradient(fx,0,fx+fw,0);
    g.addColorStop(0,'transparent'); g.addColorStop(0.15,'rgba(0,140,255,0.8)');
    g.addColorStop(0.85,'rgba(0,140,255,0.8)'); g.addColorStop(1,'transparent');
    ctx.fillStyle=g; ctx.fillRect(fx,fy,fw,2);
    const gs=ctx.createLinearGradient(0,fy+2,0,fy+5);
    gs.addColorStop(0,'rgba(0,0,0,0.4)'); gs.addColorStop(1,'transparent');
    ctx.fillStyle=gs; ctx.fillRect(fx,fy+2,fw,3);
}

/* ── Command Center floor ── */
function drawCMD(fx,fy,fw,fh) {
    /* BG */
    const bg=ctx.createLinearGradient(fx,fy,fx,fy+fh);
    bg.addColorStop(0,'#0d2040'); bg.addColorStop(1,'#061222');
    ctx.fillStyle=bg; ctx.fillRect(fx,fy,fw,fh);
    drawSkyline(fx,fy,fw,fh);

    /* floor label */
    ctx.font='bold 7px "JetBrains Mono",monospace'; ctx.textAlign='left';
    ctx.fillStyle='rgba(0,200,255,0.8)'; ctx.fillText('COMMAND CENTER', fx+10, fy+10);

    /* status dot */
    const pulse=0.7+0.3*Math.sin((af/60)*Math.PI*2);
    ctx.beginPath(); ctx.arc(fx+fw-14,fy+8,3.5,0,Math.PI*2);
    ctx.fillStyle=`rgba(0,255,128,${pulse})`; ctx.fill();
    ctx.beginPath(); ctx.arc(fx+fw-14,fy+8,6,0,Math.PI*2);
    ctx.fillStyle=`rgba(0,255,128,${pulse*0.25})`; ctx.fill();

    /* Left screen */
    const sw=Math.min(105,fw*0.14);
    drawScreen(fx+10,fy+14,sw,fh-28,[240,192,64],'ANALYTICS','pie');
    /* Right screen */
    drawScreen(fx+fw-10-sw,fy+14,sw,fh-28,[88,166,255],'NETWORK','bars');
    /* Center globe */
    const cw2=Math.min(190,fw*0.28);
    drawGlobe(fx+(fw-cw2)/2,fy+8,cw2,fh-16);

    /* Workers */
    const z=Math.min(2.2,fh/46);
    [[fw*0.22,0],[fw*0.5,1],[fw*0.78,3]].forEach(([xp,ci],i)=>{
        drawAgent(fx+xp,fy,fh,spr.chars[ci],[[240,192,64],[88,166,255],[248,113,113]][i],z);
    });

    roomHits.push({x:fx,y:fy,w:fw,h:fh, room:FLOORS[0].rooms[0]});
}

/* ── Floor row (3 rooms) ── */
function drawFRow(fx,fy,fw,fh,floor) {
    const n=floor.rooms.length, rw=Math.floor(fw/n);

    /* Label strip */
    ctx.fillStyle='rgba(0,0,0,0.28)'; ctx.fillRect(fx,fy,fw,12);
    ctx.font='bold 6px "JetBrains Mono",monospace'; ctx.textAlign='center';
    ctx.fillStyle='rgba(0,180,255,0.65)'; ctx.fillText(floor.label,fx+fw/2,fy+8.5);

    const ry=fy+12, rh=fh-12;
    floor.rooms.forEach((room,i)=>{
        const rx=fx+i*rw;
        const thisW=(i===n-1)?fw-i*rw:rw;
        if(i>0){
            const dg=ctx.createLinearGradient(rx,ry,rx,ry+rh);
            dg.addColorStop(0,'transparent');
            dg.addColorStop(0.5,`rgba(${room.accent[0]*0.4},${room.accent[1]*0.4},${room.accent[2]*0.4},0.5)`);
            dg.addColorStop(1,'transparent');
            ctx.fillStyle=dg; ctx.fillRect(rx,ry,1,rh);
        }
        drawRoom(rx,ry,thisW,rh,room);
        roomHits.push({x:rx,y:ry,w:thisW,h:rh,room});
    });
}

/* ── Individual room ── */
function drawRoom(rx,ry,rw,rh,room) {
    const [ar,ag,ab]=room.accent;

    /* BG tint */
    const bg=ctx.createLinearGradient(rx,ry,rx,ry+rh);
    bg.addColorStop(0,`rgba(${Math.floor(ar*0.05)},${Math.floor(ag*0.05)},${Math.floor(ab*0.07)},0.55)`);
    bg.addColorStop(1,'rgba(2,6,14,0)');
    ctx.fillStyle=bg; ctx.fillRect(rx,ry,rw,rh);

    /* Floor tiles */
    ctx.strokeStyle='rgba(0,40,80,0.25)'; ctx.lineWidth=0.5;
    for(let tx=rx;tx<rx+rw;tx+=14){
        ctx.beginPath(); ctx.moveTo(tx,ry+rh-8); ctx.lineTo(tx,ry+rh); ctx.stroke();
    }

    if(room.isServer){
        drawServerRacks(rx+4,ry+2,rw-8,rh-4);
    } else {
        /* Wall screen */
        const sw=Math.min(rw*0.42,58);
        drawScreen(rx+(rw-sw)/2,ry+2,sw,rh*0.44,room.accent,room.dept||'','lines');

        /* Character + desk */
        const z=Math.min(1.5,rh/54);
        const xOff = rw > 90 ? [rw*0.3, rw*0.65] : [rw*0.5];
        xOff.forEach(xp=>{
            const img=room.charIdx>=0?spr.chars[room.charIdx]:null;
            drawAgent(rx+xp,ry,rh,img,room.accent,z);
        });

        /* Plant */
        if(rw>78) drawPlant(rx+rw-12,ry+rh-16,10);
    }

    /* Lobby window */
    if(room.isLobby) drawWindow(rx+rw-18,ry+3,13,rh-8);

    /* Name tag */
    ctx.font='5.5px "JetBrains Mono",monospace'; ctx.textAlign='left';
    ctx.fillStyle=`rgba(${ar},${ag},${ab},0.8)`;
    ctx.fillText(room.eng||room.name, rx+4, ry+rh-3);
}

/* ── Character + desk at position ── */
function drawAgent(cx,fy,fh,charImg,accent,zoom) {
    const z=Math.max(1,zoom);
    const cw=16*z, ch=32*z;
    const dw=48*z, dh=15*z;
    const [ar,ag,ab]=accent;
    const deskY=fy+fh-dh-5, deskX=cx-dw/2;
    const charY=deskY-ch*0.52, charX=cx-cw/2;
    const frame=(Math.floor(af/15)%2===0)?3:4;

    /* Character sprite */
    if(charImg&&charImg.complete&&charImg.naturalWidth>0){
        ctx.save(); ctx.imageSmoothingEnabled=false;
        ctx.drawImage(charImg,frame*16,0,16,32,charX,charY,cw,ch);
        ctx.restore();
    } else { drawFallChar(charX,charY,z,ar,ag,ab); }

    /* Desk */
    if(spr.desk&&spr.desk.complete&&spr.desk.naturalWidth>0){
        ctx.save(); ctx.imageSmoothingEnabled=false;
        ctx.drawImage(spr.desk,0,16,48,16,deskX,deskY,dw,dh);
        ctx.restore();
    } else { drawFallDesk(deskX,deskY,dw,dh,ar,ag,ab); }

    /* Monitor glow on desk */
    const mg=0.35+0.2*Math.sin((af/60)*Math.PI*2);
    ctx.fillStyle=`rgba(${ar},${ag},${ab},${mg*0.12})`;
    ctx.fillRect(cx-7*z,deskY-8*z,14*z,7*z);
    ctx.strokeStyle=`rgba(${ar},${ag},${ab},${mg*0.7})`;
    ctx.lineWidth=0.5; ctx.strokeRect(cx-7*z,deskY-8*z,14*z,7*z);
}

function drawFallChar(x,y,z,r,g,b) {
    const p=Math.max(2,Math.floor(z*2));
    ctx.fillStyle='rgba(255,210,165,0.9)'; ctx.fillRect(x+p,y+p,p*3,p*3);
    ctx.fillStyle=`rgba(${r},${g},${b},0.85)`; ctx.fillRect(x+p,y,p*3,p+1);
    ctx.fillStyle='#111'; ctx.fillRect(x+p+1,y+p+1,p*0.8,p*0.7); ctx.fillRect(x+p*2+1,y+p+1,p*0.8,p*0.7);
    ctx.fillStyle=`rgba(${r},${g},${b},0.7)`; ctx.fillRect(x,y+p*4,p*5,p*4);
    ctx.fillRect(x-p,y+p*4,p,p*3); ctx.fillRect(x+p*5,y+p*4,p,p*3);
}

function drawFallDesk(dx,dy,dw,dh,r,g,b) {
    ctx.fillStyle='rgba(18,36,64,0.9)'; ctx.fillRect(dx,dy,dw,dh);
    ctx.strokeStyle=`rgba(${r},${g},${b},0.5)`; ctx.lineWidth=1; ctx.strokeRect(dx,dy,dw,dh);
    ctx.fillStyle=`rgba(${r},${g},${b},0.1)`; ctx.fillRect(dx,dy,dw,3);
}

/* ── Wall-mounted screen ── */
function drawScreen(sx,sy,sw,sh,accent,label,type) {
    if(sw<8||sh<8) return;
    const [ar,ag,ab]=accent;
    ctx.fillStyle='rgba(2,8,22,0.88)'; ctx.fillRect(sx,sy,sw,sh);
    ctx.save();
    ctx.shadowColor=`rgba(${ar},${ag},${ab},0.55)`; ctx.shadowBlur=7;
    ctx.strokeStyle=`rgba(${ar},${ag},${ab},0.85)`; ctx.lineWidth=1;
    ctx.strokeRect(sx,sy,sw,sh);
    ctx.restore();
    if(sh>12){
        ctx.font='5px "JetBrains Mono",monospace'; ctx.textAlign='center';
        ctx.fillStyle=`rgba(${ar},${ag},${ab},0.9)`; ctx.fillText(label.substring(0,10),sx+sw/2,sy+7);
    }
    const cy2=sy+10, ch2=sh-12; if(ch2<4) return;
    if(type==='pie'){
        const cx2=sx+sw/2, pr=Math.min(sw,ch2)/2-4;
        if(pr>3){
            const segs=[[0.35,[ar,ag,ab]],[0.25,[0,200,255]],[0.22,[0,255,128]],[0.18,[255,200,0]]];
            let ang=-Math.PI/2;
            segs.forEach(([pv,col])=>{
                ctx.beginPath(); ctx.moveTo(cx2,cy2+ch2/2);
                ctx.arc(cx2,cy2+ch2/2,pr,ang,ang+Math.PI*2*pv); ctx.closePath();
                ctx.fillStyle=`rgba(${col[0]},${col[1]},${col[2]},0.75)`; ctx.fill();
                ang+=Math.PI*2*pv;
            });
        }
    } else if(type==='bars'){
        const n=6, bw2=(sw-6)/(n*1.6);
        [0.6,0.8,0.5,0.9,0.7,0.6+0.25*Math.sin((af/60)*Math.PI*2)].forEach((h2,i)=>{
            const bx2=sx+3+i*(bw2+bw2*0.6), bH=ch2*h2;
            ctx.fillStyle=`rgba(${ar},${ag},${ab},0.65)`; ctx.fillRect(bx2,cy2+ch2-bH,bw2,bH);
        });
    } else {
        const n=4;
        for(let i=0;i<n;i++){
            const ly=cy2+2+i*(ch2/n);
            const lw=(sw-6)*(0.35+0.55*((i+1)/n));
            ctx.fillStyle=`rgba(${ar},${ag},${ab},${0.22+i*0.1})`; ctx.fillRect(sx+3,ly,lw,1.5);
        }
        if(af%30<15){
            const li=Math.floor(af/50)%n;
            const lw=(sw-6)*(0.35+0.55*((li+1)/n));
            ctx.fillStyle=`rgba(${ar},${ag},${ab},0.9)`; ctx.fillRect(sx+3+lw,cy2+2+li*(ch2/n),3,1.5);
        }
    }
}

/* ── Globe display (CMD center) ── */
function drawGlobe(dx,dy,dw,dh) {
    if(dw<20||dh<20) return;
    ctx.fillStyle='rgba(2,10,28,0.9)'; ctx.fillRect(dx,dy,dw,dh);
    ctx.save();
    ctx.shadowColor='rgba(0,160,255,0.6)'; ctx.shadowBlur=14;
    ctx.strokeStyle='rgba(0,160,255,0.75)'; ctx.lineWidth=1; ctx.strokeRect(dx,dy,dw,dh);
    ctx.restore();

    const cx2=dx+dw/2, cy2=dy+dh/2, r=Math.min(dw,dh)*0.33;
    const t=(af/200)*Math.PI*2;

    /* Globe fill */
    ctx.beginPath(); ctx.arc(cx2,cy2,r,0,Math.PI*2);
    const grd=ctx.createRadialGradient(cx2-r*0.3,cy2-r*0.3,0,cx2,cy2,r);
    grd.addColorStop(0,'rgba(20,80,200,0.85)');
    grd.addColorStop(0.6,'rgba(6,32,100,0.75)');
    grd.addColorStop(1,'rgba(0,10,40,0.5)');
    ctx.fillStyle=grd; ctx.fill();

    /* Grid lines */
    ctx.save(); ctx.clip();
    ctx.strokeStyle='rgba(0,180,255,0.18)'; ctx.lineWidth=0.5;
    for(let lat=-2;lat<=2;lat++){
        ctx.beginPath();
        ctx.ellipse(cx2,cy2+lat*(r*0.26),r,Math.max(2,Math.abs(Math.cos(lat*0.65))*r*0.26),0,0,Math.PI*2);
        ctx.stroke();
    }
    for(let lon=0;lon<4;lon++){
        const a=lon*Math.PI/2+t;
        ctx.beginPath();
        ctx.ellipse(cx2,cy2,Math.abs(Math.cos(a))*r,r,0,0,Math.PI*2);
        ctx.stroke();
    }
    ctx.restore();

    /* Glow ring */
    ctx.save();
    ctx.shadowColor='rgba(0,150,255,0.7)'; ctx.shadowBlur=10;
    ctx.strokeStyle='rgba(0,180,255,0.5)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(cx2,cy2,r+2,0,Math.PI*2); ctx.stroke();
    ctx.restore();

    /* Pulsing orbit ring */
    const orbR=r+8+4*Math.sin(t);
    ctx.beginPath(); ctx.arc(cx2,cy2,orbR,0,Math.PI*2);
    ctx.strokeStyle=`rgba(0,220,255,${0.28+0.2*Math.sin(t)})`; ctx.lineWidth=1.5; ctx.stroke();

    /* Moving dot on orbit */
    const dotA=t*2;
    ctx.beginPath(); ctx.arc(cx2+Math.cos(dotA)*orbR,cy2+Math.sin(dotA)*orbR,2.5,0,Math.PI*2);
    ctx.fillStyle='rgba(0,255,200,0.9)'; ctx.fill();

    ctx.font='bold 5.5px "JetBrains Mono",monospace'; ctx.textAlign='center';
    ctx.fillStyle='rgba(0,200,255,0.8)';
    ctx.fillText('AI CORE ONLINE',cx2,dy+dh-5);
}

/* ── City skyline ── */
function drawSkyline(fx,fy,fw,fh) {
    const gY=fy+fh-fh*0.12;
    const bx2s=[.05,.10,.17,.25,.31,.40,.50,.57,.64,.72,.81,.89,.96];
    const bhs  =[.28,.50,.38,.60,.33,.52,.43,.62,.38,.48,.34,.54,.42];
    const bws  =[.04,.03,.05,.04,.03,.06,.04,.03,.05,.04,.06,.03,.04];
    bx2s.forEach((bxr,i)=>{
        const bx3=fx+bxr*fw, bw2=bws[i]*fw, bh2=bhs[i]*(fh*0.38);
        ctx.fillStyle='rgba(4,14,32,0.72)'; ctx.fillRect(bx3,gY-bh2,bw2,bh2);
        /* windows */
        ctx.fillStyle='rgba(255,235,100,0.4)';
        for(let wr=0;wr<3;wr++) for(let wc=0;wc<2;wc++){
            if((wr*7+wc*3+i+Math.floor(af/60))%4!==0)
                ctx.fillRect(bx3+2+wc*4,gY-bh2+4+wr*7,2,2);
        }
    });
}

/* ── Window panel ── */
function drawWindow(wx,wy,ww,wh) {
    const ng=ctx.createLinearGradient(wx,wy,wx,wy+wh);
    ng.addColorStop(0,'rgba(10,20,65,0.9)'); ng.addColorStop(1,'rgba(4,10,30,0.9)');
    ctx.fillStyle=ng; ctx.fillRect(wx,wy,ww,wh);
    ctx.strokeStyle='rgba(80,140,255,0.35)'; ctx.lineWidth=0.5;
    ctx.strokeRect(wx,wy,ww,wh);
    ctx.beginPath(); ctx.moveTo(wx,wy+wh/2); ctx.lineTo(wx+ww,wy+wh/2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(wx+ww/2,wy); ctx.lineTo(wx+ww/2,wy+wh); ctx.stroke();
    [[2,3],[6,8],[9,2],[3,11]].forEach(([sx,sy])=>{
        ctx.fillStyle='rgba(210,230,255,0.7)'; ctx.fillRect(wx+sx%(ww-2),wy+sy%(wh-2),1,1);
    });
}

/* ── Server racks ── */
function drawServerRacks(rx,ry,rw,rh) {
    const rackW=Math.min(14,rw*0.18);
    const n=Math.min(5,Math.floor(rw/(rackW+5)));
    for(let i=0;i<n;i++){
        const rxr=rx+i*(rackW+5);
        ctx.fillStyle='rgba(18,38,72,0.85)'; ctx.fillRect(rxr,ry+3,rackW,rh-6);
        ctx.strokeStyle='rgba(0,100,200,0.5)'; ctx.lineWidth=0.5; ctx.strokeRect(rxr,ry+3,rackW,rh-6);
        const units=Math.floor((rh-10)/5);
        for(let u=0;u<units;u++){
            const act=(u*7+i*3+Math.floor(af/25))%5!==0;
            ctx.fillStyle=act?'rgba(0,255,100,0.75)':'rgba(0,60,30,0.4)';
            ctx.fillRect(rxr+2,ry+5+u*5,3,2);
            ctx.fillStyle='rgba(0,100,255,0.5)'; ctx.fillRect(rxr+rackW-4,ry+5+u*5,2,2);
        }
    }
    ctx.font='5px "JetBrains Mono",monospace'; ctx.textAlign='center';
    ctx.fillStyle='rgba(88,166,255,0.75)'; ctx.fillText('SERVER',rx+rw/2,ry+rh-1);
}

/* ── Plant ── */
function drawPlant(px,py,sz) {
    if(spr.plant&&spr.plant.complete&&spr.plant.naturalWidth>0){
        ctx.save(); ctx.imageSmoothingEnabled=false;
        ctx.drawImage(spr.plant,px-sz/2,py-sz,sz,sz); ctx.restore();
    } else {
        ctx.fillStyle='rgba(0,180,60,0.65)'; ctx.beginPath();
        ctx.arc(px,py-sz/2,sz/2,0,Math.PI*2); ctx.fill();
        ctx.fillStyle='rgba(70,35,0,0.7)'; ctx.fillRect(px-1,py-sz/2,2,sz/2);
    }
}

/* ════════════════════════════════════
   INTERACTION
════════════════════════════════════ */
canvas.addEventListener('mousemove',e=>{
    const rc=canvas.getBoundingClientRect();
    const mx=e.clientX-rc.left, my=e.clientY-rc.top;
    const h=roomHits.find(r=>mx>=r.x&&mx<=r.x+r.w&&my>=r.y&&my<=r.y+r.h);
    if(h){
        tip.style.display='block'; tip.style.left=(mx+12)+'px'; tip.style.top=(my+8)+'px';
        tip.textContent=`${h.room.eng||h.room.name} · ${h.room.dept||h.room.role||''}`;
        canvas.style.cursor='pointer';
    } else { tip.style.display='none'; canvas.style.cursor='default'; }
});
canvas.addEventListener('mouseleave',()=>{ tip.style.display='none'; });
canvas.addEventListener('click',e=>{
    const rc=canvas.getBoundingClientRect();
    const mx=e.clientX-rc.left, my=e.clientY-rc.top;
    const h=roomHits.find(r=>mx>=r.x&&mx<=r.x+r.w&&my>=r.y&&my<=r.y+r.h);
    if(h) showSel(h.room);
});

function showSel(room) {
    const el=document.getElementById('rSelected'), cnt=document.getElementById('rSelectedContent');
    el.style.display='block';
    if(room.isServer){
        cnt.innerHTML=`<div class="r-agent-card"><div class="r-agent-nm">⚙️ Server Room</div><div class="r-agent-rl">Infrastructure · Data Center</div></div>`;
    } else if(room.isLobby){
        cnt.innerHTML=`<div class="r-agent-card"><div class="r-agent-nm">🏛️ Lobby / Reception</div><div class="r-agent-rl">Ground Floor · Entry Point</div></div>`;
    } else {
        cnt.innerHTML=`<div class="r-agent-card">
            <div class="r-agent-nm">${room.eng||room.name}</div>
            <div class="r-agent-rl">${room.role||''} · ${room.dept||''}</div>
            <a class="r-agent-open" href="/Dashboard">OPEN WORKSPACE ›</a>
        </div>`;
    }
}

/* ════════════════════════════════════
   DONUT CHART
════════════════════════════════════ */
(function(){
    const c=document.getElementById('donutCanvas'); if(!c) return;
    const cx=c.getContext('2d'), R=28, CX=36, CY=36;
    cx.beginPath(); cx.arc(CX,CY,R,0,Math.PI*2);
    cx.strokeStyle='rgba(255,255,255,0.07)'; cx.lineWidth=8; cx.stroke();
    cx.beginPath(); cx.arc(CX,CY,R,-Math.PI/2,-Math.PI/2+Math.PI*2*0.75);
    cx.strokeStyle='#00c8ff'; cx.lineWidth=8; cx.lineCap='round';
    cx.shadowColor='rgba(0,200,255,0.5)'; cx.shadowBlur=8; cx.stroke(); cx.shadowBlur=0;
    cx.font='bold 10px "JetBrains Mono",monospace'; cx.textAlign='center';
    cx.fillStyle='#00c8ff'; cx.fillText('75%',CX,CY+3.5);
})();

/* ════════════════════════════════════
   DATA FLOW CHART
════════════════════════════════════ */
(function(){
    const c=document.getElementById('flowCanvas'); if(!c) return;
    const pw=c.parentElement.clientWidth-28;
    c.width=pw>20?pw:180;
    const cx=c.getContext('2d'), W=c.width, H=c.height;
    const pts=[0.40,0.58,0.36,0.72,0.50,0.66,0.44,0.78,0.55,0.62,0.82,0.67,0.52];
    cx.fillStyle='rgba(0,10,30,0.75)'; cx.fillRect(0,0,W,H);
    cx.strokeStyle='rgba(0,60,120,0.28)'; cx.lineWidth=0.5;
    for(let y=H/3;y<H;y+=H/3){ cx.beginPath(); cx.moveTo(0,y); cx.lineTo(W,y); cx.stroke(); }
    /* Fill */
    cx.beginPath(); cx.moveTo(0,H);
    pts.forEach((v,i)=>{ const x=(i/(pts.length-1))*W, y=H-v*(H-4)-2; cx.lineTo(x,y); });
    cx.lineTo(W,H); cx.closePath();
    cx.fillStyle='rgba(0,150,255,0.1)'; cx.fill();
    /* Line */
    cx.beginPath();
    pts.forEach((v,i)=>{ const x=(i/(pts.length-1))*W, y=H-v*(H-4)-2; i===0?cx.moveTo(x,y):cx.lineTo(x,y); });
    cx.strokeStyle='#00c8ff'; cx.lineWidth=1.5;
    cx.shadowColor='rgba(0,200,255,0.5)'; cx.shadowBlur=5; cx.stroke(); cx.shadowBlur=0;
    /* Dots */
    pts.forEach((v,i)=>{
        const x=(i/(pts.length-1))*W, y=H-v*(H-4)-2;
        cx.beginPath(); cx.arc(x,y,1.8,0,Math.PI*2); cx.fillStyle='#00c8ff'; cx.fill();
    });
})();
</script>
