            <div class="l-sec">
                <div class="l-sec-ttl">AI AGENTS ONLINE</div>
                <div class="l-avatars">
                    <div class="l-av"><div class="l-av-icon">🤖</div><div class="l-av-name">ALPHA</div></div>
                    <div class="l-av"><div class="l-av-icon">🦾</div><div class="l-av-name">BETA</div></div>
                    <div class="l-av"><div class="l-av-icon">⚙️</div><div class="l-av-name">GAMMA</div></div>
                    <div class="l-av"><div class="l-av-icon">🧠</div><div class="l-av-name">DELTA</div></div>
