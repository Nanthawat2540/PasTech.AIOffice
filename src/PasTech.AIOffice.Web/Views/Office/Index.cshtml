<style>
@@keyframes livepulse { 0%,100%{opacity:1} 50%{opacity:.3} }
</style>

@section Scripts {
<script>
'use strict';

/* ── Clock ── */
const MONTHS=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
function tick(){
    const n=new Date(),p=v=>String(v).padStart(2,'0');
    document.getElementById('lTime').textContent=`${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}`;
    document.getElementById('lDate').textContent=`DATE: ${p(n.getDate())} ${MONTHS[n.getMonth()]} ${n.getFullYear()}`;
}
tick(); setInterval(tick,1000);

/* ── Canvas ── */
const canvas=document.getElementById('officeCanvas');
const ctx=canvas.getContext('2d');
const wrap=document.getElementById('canvasWrap');
const tip=document.getElementById('cTip');
function resize(){canvas.width=wrap.clientWidth;canvas.height=wrap.clientHeight;}
resize(); window.addEventListener('resize',()=>{resize();});

/* ══════════════════════════════════════════════════════
   ASSET LOADING
══════════════════════════════════════════════════════ */
const DESK_REPO = 'https://raw.githubusercontent.com/zep-ia/pixel-agent-desk/master/public';

const assets = { mapBg:null, mapFg:null };
let loadedCount=0;

function setLoad(sub){document.getElementById('loadSub').textContent=sub;}
function pctLoad(){
    document.getElementById('loadFill').style.width=(loadedCount>=2?100:50)+'%';
}
function ldImg(src){
    return new Promise(res=>{
        const img=new Image(); img.crossOrigin='anonymous';
        img.onload=()=>{loadedCount++;pctLoad();res(img);};
        img.onerror=()=>{loadedCount++;pctLoad();res(null);};
        img.src=src;
    });
}

async function boot(){
    setLoad('Loading office map...');
    assets.mapBg = await ldImg(`${DESK_REPO}/office/map/office_bg_32.webp`);
    assets.mapFg = await ldImg(`${DESK_REPO}/office/map/office_fg_32.webp`);
    setLoad('Ready!');
    document.getElementById('loadOv').classList.add('gone');
    initAgents();
    startLoop();
}
boot();

/* ══════════════════════════════════════════════════════
   AGENT DATA & STATE MACHINE
══════════════════════════════════════════════════════ */
/*
  Agent positions are defined as fractions [0-1] of the canvas.
  Based on the reference screenshot of pixel-agent-desk office map.
  Desk positions correspond to the office_bg_32.webp layout.
*/
/* ─────────────────────────────────────────────
   PasTech AI Agent Roster  (10 agents)
   Domains: CCTV · Network · Server · Solar · Smart Building
   Channels: ERP · Facebook · Line OA
───────────────────────────────────────────── */
const AGENT_DEFS = [
    // id, name, label, av(color idx), tx, ty (fraction of canvas), initStatus
    { id:'aria',   name:'ARIA',   label:'cmd-director',   av:0, tx:0.64, ty:0.19, st:'DONE'    },
    { id:'victor', name:'Victor', label:'sales-engineer',  av:1, tx:0.44, ty:0.42, st:'THINKING' },
    { id:'sam',    name:'Sam',    label:'field-engineer',  av:2, tx:0.34, ty:0.57, st:'THINKING' },
    { id:'noah',   name:'Noah',   label:'commercial-mgr',  av:3, tx:0.46, ty:0.65, st:'THINKING' },
    { id:'emma',   name:'Emma',   label:'project-mgr',     av:4, tx:0.22, ty:0.80, st:'THINKING' },
    { id:'eric',   name:'Eric',   label:'tech-writer',     av:5, tx:0.38, ty:0.80, st:'THINKING' },
    { id:'chris',  name:'Chris',  label:'support-eng',     av:6, tx:0.19, ty:0.48, st:'THINKING' },
    { id:'maya',   name:'Maya',   label:'digital-mktg',    av:7, tx:0.60, ty:0.55, st:'THINKING' },
    { id:'iris',   name:'Iris',   label:'inbox-monitor',   av:0, tx:0.30, ty:0.31, st:'THINKING' },
    { id:'rex',    name:'Rex',    label:'erp-agent',       av:3, tx:0.52, ty:0.31, st:'THINKING' },
];

let AGENTS=[];
const STATUS_DUR = { THINKING:[160,320], DONE:[60,100], IDLE:[80,180] };

function rnd(lo,hi){return Math.floor(Math.random()*(hi-lo+1))+lo;}

function initAgents(){
    AGENTS = AGENT_DEFS.map(d=>({
        ...d,
        x: d.tx * canvas.width,  y: d.ty * canvas.height,
        px:0, py:0,              // pixel position (computed each frame)
        dir: 2,                  // 0=down,1=up,2=right,3=left
        walkFrame: 0,
        walkTimer: 0,
        status: d.st,
        statusTimer: rnd(...STATUS_DUR[d.st]),
        wander: null,            // { tx, ty } wander target or null
        ellipsis: 0,             // animation counter for "..."
    }));
}

function updateAgents(W,H){
    AGENTS.forEach(a=>{
        a.px = a.tx * W;
        a.py = a.ty * H;

        // Walk animation
        a.walkTimer = (a.walkTimer+1)%12;
        if(a.walkTimer===0) a.walkFrame=(a.walkFrame+1)%4;

        // Wander movement
        if(a.wander){
            const wx=a.wander.tx*W, wy=a.wander.ty*H;
            const dx=wx-a.px, dy=wy-a.py;
            const dist=Math.sqrt(dx*dx+dy*dy);
            if(dist < 2){
                a.wander=null;
            } else {
                const speed=0.9;
                const nx=a.tx+dx/dist*speed/W;
                const ny=a.ty+dy/dist*speed/H;
                a.tx+=nx-a.tx; a.ty+=ny-a.ty;
                // Direction from movement
                if(Math.abs(dx)>Math.abs(dy)) a.dir=dx>0?2:3;
                else a.dir=dy>0?0:1;
            }
        }

        // Status timer
        a.statusTimer--;
        if(a.statusTimer<=0){
            const next = a.status==='THINKING'?'DONE': a.status==='DONE'?'IDLE':'THINKING';
            a.status=next;
            a.statusTimer=rnd(...STATUS_DUR[next]);
            // On IDLE: walk somewhere nearby
            if(next==='IDLE'&&!a.wander){
                a.wander={
                    tx: Math.max(0.05,Math.min(0.95,AGENT_DEFS.find(d=>d.id===a.id).tx+(Math.random()-.5)*0.08)),
                    ty: Math.max(0.05,Math.min(0.95,AGENT_DEFS.find(d=>d.id===a.id).ty+(Math.random()-.5)*0.07)),
                };
            }
            if(next==='THINKING'&&!a.wander){
                // walk back to desk
                const def=AGENT_DEFS.find(d=>d.id===a.id);
                a.wander={tx:def.tx, ty:def.ty};
            }
        }

        a.ellipsis=(a.ellipsis+1)%60;
    });
}

/* ══════════════════════════════════════════════════════
   RENDER LOOP
══════════════════════════════════════════════════════ */
let af=0, hitRects=[];

function startLoop(){
    const FPS=1000/24; let last=0;
    (function loop(ts){
        if(ts-last>=FPS){last=ts;af=(af+1)%600;
            const W=canvas.width, H=canvas.height;
            hitRects=[];
            updateAgents(W,H);
            drawScene(W,H);
        }
        requestAnimationFrame(loop);
    })(0);
}

/* ══════════════════════════════════════════════════════
   SCENE DRAWING
══════════════════════════════════════════════════════ */
function drawScene(W,H){
    ctx.clearRect(0,0,W,H);

    // 1. Office background map
    if(assets.mapBg&&assets.mapBg.complete&&assets.mapBg.naturalWidth>0){
        ctx.imageSmoothingEnabled=false;
        ctx.drawImage(assets.mapBg,0,0,W,H);
    } else {
        drawFallbackOffice(W,H);
    }

    // 2. Agents (between bg and fg layers)
    AGENTS.forEach(a=>drawAgent(a,W,H));

    // 3. Office foreground (tables, etc. overlay on top of characters)
    if(assets.mapFg&&assets.mapFg.complete&&assets.mapFg.naturalWidth>0){
        ctx.imageSmoothingEnabled=false;
        ctx.drawImage(assets.mapFg,0,0,W,H);
    }

    // 4. Speech bubbles (topmost)
    AGENTS.forEach(a=>{ if(a.status!=='IDLE') drawBubble(a,W,H); });

    // 5. LIVE indicator
    drawLive(W,H);
}

/* ── Fallback office (if map fails to load) ── */
function drawFallbackOffice(W,H){
    // Grass exterior
    ctx.fillStyle='#4c7a30'; ctx.fillRect(0,0,W,H);
    // Grass texture
    for(let gx=0;gx<W;gx+=18) for(let gy=0;gy<H;gy+=18){
        if((gx/18+gy/18)%3===0){ctx.fillStyle='#527a30';ctx.fillRect(gx+3,gy+3,5,5);}
    }
    const P=12, G=5;
    const rooms=[
        {x:P,y:P,w:W*.25,h:H*.4,c:'#c8935a',name:'Break Room'},
        {x:P+W*.25+G,y:P,w:W*.42,h:H*.58,c:'#d0c8bc',name:'Open Office'},
        {x:W-P-W*.27,y:P,w:W*.27,h:H*.38,c:'#c8b880',name:'Meeting Room'},
        {x:P,y:P+H*.4+G,w:W*.14,h:H*.2,c:'#909090',name:'Server'},
        {x:P,y:P+H*.4+H*.2+G*2,w:W*.46,h:H*.36,c:'#e0d8d0',name:'Dev Desks'},
        {x:W-P-W*.27,y:P+H*.38+G,w:W*.27,h:H*.58,c:'#7a8880',name:'Conference'},
    ];
    rooms.forEach(r=>{
        ctx.fillStyle=r.c; ctx.fillRect(r.x,r.y,r.w,r.h);
        if(r.name==='Dev Desks'){ // checker
            const sz=16; ctx.fillStyle='#ccc8c0';
            for(let cx2=r.x;cx2<r.x+r.w;cx2+=sz) for(let cy2=r.y;cy2<r.y+r.h;cy2+=sz)
                if(((cx2-r.x)/sz+(cy2-r.y)/sz)%2===0) ctx.fillRect(cx2,cy2,Math.min(sz,r.x+r.w-cx2),Math.min(sz,r.y+r.h-cy2));
        }
        if(r.name==='Break Room'){
            ctx.strokeStyle='rgba(100,60,20,.15)'; ctx.lineWidth=.8;
            for(let fy=r.y;fy<r.y+r.h;fy+=16){ctx.beginPath();ctx.moveTo(r.x,fy);ctx.lineTo(r.x+r.w,fy);ctx.stroke();}
        }
        ctx.strokeStyle='rgba(80,60,40,.5)'; ctx.lineWidth=2; ctx.strokeRect(r.x,r.y,r.w,r.h);
        ctx.font='bold 9px sans-serif'; ctx.textAlign='left'; ctx.fillStyle='rgba(60,40,20,.45)';
        ctx.fillText(r.name,r.x+5,r.y+13);
        // Desk furniture
        drawRoomFurniture(r);
    });
    // Trees
    [[22,18],[70,14],[140,20],[W-60,16],[W-120,18],[W-25,H*.3],[18,H*.6]].forEach(([tx,ty])=>drawTree(tx,ty,16));
}

function drawTree(tx,ty,r){
    ctx.fillStyle='rgba(0,0,0,.12)'; ctx.beginPath(); ctx.ellipse(tx,ty+r*1.1,r*.55,r*.22,0,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#5c3a18'; ctx.fillRect(tx-2,ty,4,r*.55);
    [[r*1.15,'#2d6a2d'],[r*.95,'#3a883a'],[r*.7,'#4aaa4a']].forEach(([cr,col],i)=>{
        ctx.beginPath(); ctx.arc(tx,ty-i*r*.22,cr,0,Math.PI*2); ctx.fillStyle=col; ctx.fill();
    });
}

function drawRoomFurniture(r){
    if(r.name==='Open Office'||r.name==='Dev Desks'){
        const dw=22,dh=14; let row=0,col=0;
        while(r.y+28+row*(dh+18)<r.y+r.h-10){
            while(r.x+18+col*(dw+16)<r.x+r.w-10){
                const dx=r.x+18+col*(dw+16), dy=r.y+28+row*(dh+18);
                ctx.fillStyle='#7a5030'; ctx.fillRect(dx,dy,dw,dh);
                ctx.fillStyle='#111'; ctx.fillRect(dx+3,dy+2,12,8); // screen
                ctx.fillStyle='rgba(0,180,255,.5)'; ctx.fillRect(dx+4,dy+3,10,6); // screen glow
                col++;
            }
            col=0; row++;
        }
    }
}

/* ── Draw single agent ── */
function drawAgent(a,W,H){
    const cx=a.px, cy=a.py;
    drawPixelChar(cx,cy,a.av,a.walkFrame);

    hitRects.push({x:cx-20,y:cy-54,w:40,h:58,agent:a});
}

/* RPG-style pixel character: head/hair/body/arms/legs/shadow */
function drawPixelChar(cx,cy,idx,walkPhase){
    const SHIRTS=[[88,166,255],[251,191,36],[34,211,238],[248,113,113],[52,211,153],[251,146,60],[167,139,250],[240,192,64]];
    const HAIRS=['#1a1008','#4a3010','#152840','#3a1010','#102a10','#4a1e04','#1a1040','#2a1c04'];
    const [sr,sg,sb]=SHIRTS[idx%SHIRTS.length];
    const hair=HAIRS[idx%HAIRS.length];
    const p=3.5; // pixel unit size
    const leg=Math.sin((walkPhase/4)*Math.PI)*p*0.85;

    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.22)';
    ctx.beginPath(); ctx.ellipse(cx,cy-1,p*2.8,p*0.7,0,0,Math.PI*2); ctx.fill();

    // Legs (animated)
    ctx.fillStyle='#2e3d58';
    ctx.fillRect(Math.round(cx-p*1.4), Math.round(cy-p*3.8+leg),  Math.round(p), Math.round(p*3.8));
    ctx.fillRect(Math.round(cx+p*0.4), Math.round(cy-p*3.8-leg),  Math.round(p), Math.round(p*3.8));
    // Shoes
    ctx.fillStyle='#111820';
    ctx.fillRect(Math.round(cx-p*1.6), Math.round(cy-1.5+leg),    Math.round(p*1.4), Math.round(p*0.7));
    ctx.fillRect(Math.round(cx+p*0.2), Math.round(cy-1.5-leg),    Math.round(p*1.4), Math.round(p*0.7));

    // Body / shirt
    ctx.fillStyle=`rgba(${sr},${sg},${sb},0.95)`;
    ctx.fillRect(Math.round(cx-p*2),   Math.round(cy-p*7.5),  Math.round(p*4),  Math.round(p*3.7));
    // Belt
    ctx.fillStyle=`rgba(${Math.max(0,sr-50)},${Math.max(0,sg-50)},${Math.max(0,sb-50)},0.8)`;
    ctx.fillRect(Math.round(cx-p*2),   Math.round(cy-p*4.2),  Math.round(p*4),  Math.round(p*0.6));

    // Arms (swing with legs)
    const armSwing=leg*0.5;
    ctx.fillStyle=`rgba(${Math.max(0,sr-25)},${Math.max(0,sg-25)},${Math.max(0,sb-25)},0.9)`;
    ctx.fillRect(Math.round(cx-p*3.1), Math.round(cy-p*7.2+armSwing), Math.round(p), Math.round(p*3));
    ctx.fillRect(Math.round(cx+p*2.1), Math.round(cy-p*7.2-armSwing), Math.round(p), Math.round(p*3));
    // Hands
    ctx.fillStyle='rgba(255,200,150,0.9)';
    ctx.fillRect(Math.round(cx-p*3.2), Math.round(cy-p*4.5+armSwing), Math.round(p*1.2), Math.round(p));
    ctx.fillRect(Math.round(cx+p*2),   Math.round(cy-p*4.5-armSwing), Math.round(p*1.2), Math.round(p));

    // Neck
    ctx.fillStyle='rgba(255,205,155,0.9)';
    ctx.fillRect(Math.round(cx-p*0.5), Math.round(cy-p*7.8), Math.round(p), Math.round(p*0.8));

    // Head
    ctx.fillStyle='rgba(255,208,158,0.97)';
    ctx.fillRect(Math.round(cx-p*1.8), Math.round(cy-p*11.8), Math.round(p*3.6), Math.round(p*4));
    // Ears
    ctx.fillStyle='rgba(240,190,140,0.8)';
    ctx.fillRect(Math.round(cx-p*2.3), Math.round(cy-p*10.5), Math.round(p*0.7), Math.round(p*1.5));
    ctx.fillRect(Math.round(cx+p*1.6), Math.round(cy-p*10.5), Math.round(p*0.7), Math.round(p*1.5));

    // Hair
    ctx.fillStyle=hair;
    ctx.fillRect(Math.round(cx-p*1.8), Math.round(cy-p*11.8), Math.round(p*3.6), Math.round(p*1.2)); // top
    ctx.fillRect(Math.round(cx-p*1.8), Math.round(cy-p*10.8), Math.round(p*0.9), Math.round(p*2.2)); // left side
    ctx.fillRect(Math.round(cx+p*0.9), Math.round(cy-p*10.8), Math.round(p*0.9), Math.round(p*1.5)); // right side

    // Eyes
    ctx.fillStyle='#0e1520';
    ctx.fillRect(Math.round(cx-p*1.1), Math.round(cy-p*10), Math.round(p*0.8), Math.round(p*0.8));
    ctx.fillRect(Math.round(cx+p*0.3), Math.round(cy-p*10), Math.round(p*0.8), Math.round(p*0.8));
    // Eye whites
    ctx.fillStyle='rgba(220,235,255,0.7)';
    ctx.fillRect(Math.round(cx-p*1.1), Math.round(cy-p*10.1), Math.round(p*0.5), Math.round(p*0.5));
    ctx.fillRect(Math.round(cx+p*0.3), Math.round(cy-p*10.1), Math.round(p*0.5), Math.round(p*0.5));
    // Mouth
    ctx.fillStyle='rgba(160,80,60,0.6)';
    ctx.fillRect(Math.round(cx-p*0.4), Math.round(cy-p*8.4), Math.round(p*0.8), Math.round(p*0.4));
}

/* ── Speech bubble (pixel-agent-desk style) ── */
function drawBubble(a,W,H){
    const cx=a.px, cy=a.py-52;
    const dots=['.','..','. . .'][Math.floor(a.ellipsis/20)%3];
    const txt=a.status==='DONE'?'Done!':('Thinking'+dots);
    const badgeTxt=a.status;
    const agentLbl=a.label;
    const badgeCol=a.status==='DONE'?[34,197,94]:[147,51,234];

    ctx.font='bold 11px sans-serif';
    const tw=ctx.measureText(txt).width;
    const bw=Math.max(tw+20,80), bh=22;
    const bx=cx-bw/2, by=cy-bh-10;

    // White speech bubble
    ctx.save();
    ctx.shadowColor='rgba(0,0,0,.2)'; ctx.shadowBlur=6;
    ctx.fillStyle='rgba(255,255,255,.96)';
    rr(ctx,bx,by,bw,bh,5); ctx.fill();
    ctx.restore();
    ctx.strokeStyle='rgba(180,180,180,.6)'; ctx.lineWidth=.8;
    rr(ctx,bx,by,bw,bh,5); ctx.stroke();

    // Bubble tail
    ctx.fillStyle='rgba(255,255,255,.96)';
    ctx.beginPath(); ctx.moveTo(cx-5,by+bh); ctx.lineTo(cx,by+bh+8); ctx.lineTo(cx+5,by+bh); ctx.closePath(); ctx.fill();
    ctx.strokeStyle='rgba(180,180,180,.4)';
    ctx.beginPath(); ctx.moveTo(cx-5,by+bh); ctx.lineTo(cx,by+bh+8); ctx.lineTo(cx+5,by+bh); ctx.stroke();

    // Bubble text
    ctx.font='bold 11px sans-serif'; ctx.textAlign='center';
    ctx.fillStyle='#222'; ctx.fillText(txt,cx,by+bh-6);

    // Status badge
    const [br,bg2,bb]=badgeCol;
    const bdW=Math.max(ctx.measureText(badgeTxt).width+16,65);
    const bdY=by+bh+10;
    ctx.fillStyle=`rgba(${br},${bg2},${bb},0.9)`;
    rr(ctx,cx-bdW/2,bdY,bdW,16,3); ctx.fill();
    ctx.font='bold 9px "JetBrains Mono",monospace'; ctx.textAlign='center';
    ctx.fillStyle='#fff'; ctx.fillText(badgeTxt,cx,bdY+11);

    // Agent name badge
    ctx.font='8px "JetBrains Mono",monospace';
    const nmW=Math.max(ctx.measureText(agentLbl).width+14,70);
    const nmY=bdY+18;
    ctx.fillStyle='rgba(30,30,50,.85)';
    rr(ctx,cx-nmW/2,nmY,nmW,14,3); ctx.fill();
    ctx.fillStyle='rgba(140,180,255,.9)'; ctx.fillText(agentLbl,cx,nmY+10);
}

function rr(c,x,y,w,h,r){
    c.beginPath();
    c.moveTo(x+r,y); c.lineTo(x+w-r,y); c.quadraticCurveTo(x+w,y,x+w,y+r);
    c.lineTo(x+w,y+h-r); c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    c.lineTo(x+r,y+h); c.quadraticCurveTo(x,y+h,x,y+h-r);
    c.lineTo(x,y+r); c.quadraticCurveTo(x,y,x+r,y);
    c.closePath();
}

