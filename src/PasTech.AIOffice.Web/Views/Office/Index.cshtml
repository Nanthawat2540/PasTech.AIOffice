@section Scripts {
<script>
// ── Stars ──
const starsContainer = document.getElementById('stars');
for (let i = 0; i < 80; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 2.5 + .5;
    s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-delay:${Math.random()*3}s;animation-duration:${2+Math.random()*3}s`;
    starsContainer.appendChild(s);
}

// ── Clock ──
function tick() {
    const n = new Date();
    document.getElementById('clock').textContent =
        n.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick, 1000);

// ── Agent Data ──
const agents = {
    ceo:       { name:'บอส (BOSS)',       title:'CEO / Orchestrator',         color:'#f0c040', emoji:'👑', dept:'Command Center',  hint:'มอบหมายงาน หรือถามภาพรวมบริษัท...', agentType: null },
    sales:     { name:'สมหมาย (Sommai)',  title:'Sales Manager',              color:'#60a5fa', emoji:'💼', dept:'Sales Office',     hint:'วางข้อความจากลูกค้าได้เลย เช่น: "สอบถามกล้องวงจรปิด..."', agentType: 1 },
    survey:    { name:'วิศว (Wit)',        title:'Senior Engineer',            color:'#22d3ee', emoji:'⚙️', dept:'Design Studio',    hint:'ระบุข้อมูลหน้างาน: พื้นที่, จำนวนจุด, ระบบที่ต้องการ...', agentType: 2 },
    quotation: { name:'นับทอง (Nab)',     title:'Quotation Specialist',        color:'#fbbf24', emoji:'💰', dept:'Finance Office',   hint:'วาง BOM จาก Survey Agent เพื่อทำใบเสนอราคา...', agentType: 3 },
    project:   { name:'ปิ่น (Pim)',       title:'Project Manager',             color:'#f87171', emoji:'📅', dept:'War Room',         hint:'วาง Quotation ที่อนุมัติแล้ว + วันเริ่มงาน...', agentType: 4 },
    document:  { name:'เอก (Ek)',         title:'Technical Writer',            color:'#34d399', emoji:'📄', dept:'Document Center',  hint:'ระบุรายการอุปกรณ์ที่ติดตั้งจริงเพื่อทำ As-Built...', agentType: 5 },
    support:   { name:'ช่วย (Chuai)',     title:'Support Engineer',            color:'#fb923c', emoji:'🛠️', dept:'Support Center',   hint:'บอกอาการที่ลูกค้าแจ้ง เช่น: "กล้องไม่ขึ้นภาพ..."', agentType: 6 },
    marketing: { name:'มายา (Maya)',      title:'Marketing Manager',           color:'#a78bfa', emoji:'📣', dept:'Creative Studio',  hint:'สรุปงานที่เสร็จแล้ว เช่น: "CCTV 28 จุด โรงงานชลบุรี"...', agentType: 7 },
};

let currentAgent = null;

function selectAgent(key) {
    currentAgent = key;
    document.querySelectorAll('.floor').forEach(f => f.classList.remove('active'));
    event.currentTarget.classList.add('active');
    const a = agents[key];
    moveElevator(key);
    document.getElementById('agentPanel').innerHTML = `
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
            <div style="width:48px;height:48px;border-radius:10px;background:${a.color}22;border:1px solid ${a.color}44;display:flex;align-items:center;justify-content:center;font-size:1.5rem">${a.emoji}</div>
            <div>
                <div style="font-weight:700;color:${a.color}">${a.name}</div>
                <div style="font-size:.72rem;color:var(--muted)">${a.title} · ${a.dept}</div>
            </div>
        </div>
        ${a.agentType ? `
        <form onsubmit="runAgent(event,'${key}')">
            <input type="hidden" name="agentType" value="${a.agentType}">
            <div style="margin-bottom:.75rem">
                <label style="font-size:.78rem;color:var(--muted);display:block;margin-bottom:.3rem">Input / คำสั่ง</label>
                <textarea name="input" rows="4" placeholder="${a.hint}" style="background:#0d1117;border:1px solid #30363d;color:#e6edf3;border-radius:6px;width:100%;padding:.5rem .75rem;font-size:.83rem;resize:vertical"></textarea>
            </div>
            <button type="submit" style="background:${a.color};border:none;color:#0d1117;padding:.5rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;width:100%;font-size:.85rem">▶ Run ${a.name}</button>
        </form>
        ` : `<p style="color:var(--muted);font-size:.85rem">CEO คือ Orchestrator — ใช้ Dashboard เพื่อจัดการงานทั้งหมด</p><a href="/Dashboard" style="display:block;text-align:center;background:#f0c040;color:#0d1117;padding:.5rem;border-radius:6px;font-weight:700;text-decoration:none;margin-top:.75rem">→ ไป Dashboard</a>`}
    `;
}

const floorMap = { ceo: 4, marketing: 36, support: 108, document: 180, project: 252, quotation: 324, survey: 396, sales: 468 };
function moveElevator(key) {
    const car = document.getElementById('elevatorCar');
    if (car) car.style.top = (floorMap[key] || 4) + 'px';
}

function openAgentModal(key) {
    const a = agents[key];
    document.getElementById('modalContent').innerHTML = `
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
            <div style="width:56px;height:56px;border-radius:12px;background:${a.color}22;border:2px solid ${a.color}44;display:flex;align-items:center;justify-content:center;font-size:2rem">${a.emoji}</div>
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:${a.color}">${a.name}</div>
                <div style="color:var(--muted);font-size:.8rem">${a.title} · ${a.dept}</div>
            </div>
        </div>
        ${a.agentType ? `
        <form onsubmit="runAgent(event,'${key}');closeModal()">
            <label style="font-size:.8rem;color:var(--muted);display:block;margin-bottom:.5rem">Input ถึง ${a.name}</label>
            <textarea name="input" rows="6" placeholder="${a.hint}" style="background:#0d1117;border:1px solid #30363d;color:#e6edf3;border-radius:6px;width:100%;padding:.75rem;font-size:.85rem;resize:vertical;margin-bottom:1rem"></textarea>
            <div style="display:flex;gap:.75rem">
                <button type="button" onclick="closeModal()" style="flex:1;background:transparent;border:1px solid #30363d;color:var(--muted);padding:.6rem;border-radius:6px;cursor:pointer">ยกเลิก</button>
                <button type="submit" style="flex:2;background:${a.color};border:none;color:#0d1117;padding:.6rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:.9rem">▶ Run Agent</button>
            </div>
        </form>
        ` : `<p style="color:var(--muted)">ใช้ Dashboard สำหรับ CEO Orchestrator</p>`}
    `;
    document.getElementById('agentModal').classList.add('open');
}

function closeModal(e) {
    if (!e || e.target === document.getElementById('agentModal'))
        document.getElementById('agentModal').classList.remove('open');
}

async function runAgent(e, key) {
    e.preventDefault();
    const a = agents[key];
    const form = e.target;
    const input = form.querySelector('[name=input]')?.value;
    if (!input) return;
    const dot = document.getElementById('status-' + key);
    if (dot) { dot.className = 'char-status-dot working'; }
    const btn = form.querySelector('button[type=submit]');
    if (btn) { btn.disabled = true; btn.textContent = '⏳ กำลังทำงาน...'; }
    // Redirect to Dashboard with agent pre-selected (simplified)
    setTimeout(() => { window.location.href = '/Dashboard'; }, 500);
}
</script>
}
