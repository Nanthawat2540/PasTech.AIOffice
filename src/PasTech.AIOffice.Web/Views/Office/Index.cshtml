                <div class="r-dept"><span class="r-dept-n">1.</span><span class="r-dept-nm">Admin</span><span class="r-dept-pct gv">100%</span></div>
                <div class="r-dept"><span class="r-dept-n">2.</span><span class="r-dept-nm">R&amp;D</span><span class="r-dept-pct gv">95%</span></div>
