/* ══════════════════════════════════════════════════════
   MOUSE INTERACTION
══════════════════════════════════════════════════════ */
canvas.addEventListener('mousemove',e=>{
    const rc=canvas.getBoundingClientRect();
    const mx=e.clientX-rc.left, my=e.clientY-rc.top;
    const h=hitRects.find(r=>mx>=r.x&&mx<=r.x+r.w&&my>=r.y&&my<=r.y+r.h);
    if(h){
        tip.style.display='block'; tip.style.left=(mx+12)+'px'; tip.style.top=(my-4)+'px';
        tip.textContent=`${h.agent.name} · ${h.agent.label} · ${h.agent.status}`;
        canvas.style.cursor='pointer';
    } else { tip.style.display='none'; canvas.style.cursor='default'; }
});
canvas.addEventListener('mouseleave',()=>{tip.style.display='none';});
canvas.addEventListener('click',e=>{
    const rc=canvas.getBoundingClientRect();
    const mx=e.clientX-rc.left, my=e.clientY-rc.top;
    const h=hitRects.find(r=>mx>=r.x&&mx<=r.x+r.w&&my>=r.y&&my<=r.y+r.h);
    if(h) showSel(h.agent);
});

