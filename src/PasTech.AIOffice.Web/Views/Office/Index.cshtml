@{
    Layout = "_OfficeLayout";
    ViewData["Title"] = "AI Office HQ";
}

<div class="hq-page">

    <!-- ══════════════════ LEFT PANEL ══════════════════ -->
    <div class="hq-left">
        <div class="l-head">
            <div class="l-brand">AI OFFICE <sup>v1.0</sup></div>
            <div class="l-time">TIME: <span id="lTime">--:--</span></div>
            <div class="l-date" id="lDate">DATE: -- --- ----</div>
        </div>

        <div class="l-scroll">
            <div class="l-sec">
                <div class="l-sec-ttl">COMPANY STATUS</div>
                <div class="l-stat"><span class="l-stat-lbl">OPERATIONAL</span><span class="l-stat-val gv">100%</span></div>
