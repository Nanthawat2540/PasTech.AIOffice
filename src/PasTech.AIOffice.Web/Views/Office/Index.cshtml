                <div class="r-dept"><span class="r-dept-n">4.</span><span class="r-dept-nm">Operations</span><span class="r-dept-pct cv">92%</span></div>
                <div class="r-dept"><span class="r-dept-n">5.</span><span class="r-dept-nm">Finance</span><span class="r-dept-pct gv">97%</span></div>
                <div class="r-dept"><span class="r-dept-n">6.</span><span class="r-dept-nm">Marketing</span><span class="r-dept-pct yv">78%</span></div>
                <div class="r-dept"><span class="r-dept-n">7.</span><span class="r-dept-nm">IT Support</span><span class="r-dept-pct gv">99%</span></div>
            </div>

            <div class="r-sec">
                <div class="r-sec-ttl">ACTIVE PROJECTS</div>
                <div class="r-proj"><span class="r-proj-nm">AI Chatbot System</span><span class="r-prog-badge">IN PROGRESS</span></div>
                <div class="r-proj"><span class="r-proj-nm">Network Upgrade</span><span class="r-prog-badge">IN PROGRESS</span></div>
                <div class="r-proj"><span class="r-proj-nm">ERP Integration</span><span class="r-prog-badge">IN PROGRESS</span></div>
                <div class="r-proj"><span class="r-proj-nm">Data Analytics v2</span><span class="r-prog-badge">IN PROGRESS</span></div>
                <div class="r-proj"><span class="r-proj-nm">Security Audit</span><span class="r-prog-badge">IN PROGRESS</span></div>
