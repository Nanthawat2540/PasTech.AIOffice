@section Scripts {
<script>
const AGENTS = {
    cmd:       { name:'Boss (Director)', role:'Command Center · CEO', link:'/Office' },
    sales:     { name:'สมหมาย (Sommai)', role:'Sales Manager · ฝ่ายขาย', link:'/Dashboard' },
    survey:    { name:'วิท (Wit)', role:'Survey & Design · สำรวจ&ออกแบบ', link:'/Dashboard' },
    quotation: { name:'นาบ (Nab)', role:'Quotation Specialist · ใบเสนอราคา', link:'/Dashboard' },
    project:   { name:'พิม (Pim)', role:'Project Manager · จัดการโครงการ', link:'/Dashboard' },
    document:  { name:'เอก (Ek)', role:'Document Officer · งานเอกสาร', link:'/Dashboard' },
    support:   { name:'ช่วย (Chuai)', role:'Support Engineer · ซ่อมบำรุง', link:'/Dashboard' },
    marketing: { name:'มายา (Maya)', role:'Marketing Manager · การตลาด', link:'/Dashboard' },
    server:    { name:'AI Core Engine', role:'Server Room · Infrastructure', link:'/Dashboard' },
    lobby:     { name:'Lobby', role:'Reception / Visitor Area', link:'/Dashboard' },
};

let curRoom = null;
function selectRoom(id) {
    if (curRoom) document.getElementById('room-'+curRoom)?.classList.remove('active');
    curRoom = id;
    document.getElementById('room-'+id)?.classList.add('active');
    const a = AGENTS[id] || {};
    document.getElementById('rp-agent-name').textContent = a.name || id;
    document.getElementById('rp-agent-role').textContent = a.role || '';
}
function openModal(id) {
    const a = AGENTS[id] || {};
    document.getElementById('modal-title').textContent = a.name || id;
    document.getElementById('modal-role').textContent  = a.role || '';
    document.getElementById('modal-link').href = a.link || '/Dashboard';
    document.getElementById('agentModal').classList.add('open');
}
function closeModal() { document.getElementById('agentModal').classList.remove('open'); }

// Generate stars
(function() {
    const s = document.querySelector('.stars');
    for (let i = 0; i < 55; i++) {
        const d = document.createElement('div'); d.className = 'star';
        const sz = (Math.random()*1.4+.4).toFixed(1)+'px';
        d.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;width:${sz};height:${sz};animation-delay:${(Math.random()*5).toFixed(2)}s;animation-duration:${(Math.random()*3+2).toFixed(1)}s`;
        s.appendChild(d);
    }
})();

// Clock
function tick() {
    const now = new Date();
    const t = now.toLocaleTimeString('th-TH', { hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false });
    const d = now.toLocaleDateString('th-TH', { weekday:'short', year:'2-digit', month:'short', day:'numeric' });
    const lc = document.getElementById('lp-clock'); if (lc) lc.textContent = t;
    const ld = document.getElementById('lp-date');  if (ld) ld.textContent = d;
    const bc = document.getElementById('base-clock'); if (bc) bc.textContent = t;
}
tick(); setInterval(tick, 1000);
</script>
}
