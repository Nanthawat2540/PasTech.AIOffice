                <div class="wf-step"><div class="wf-step-icon">💡</div><div class="wf-step-lbl">DECISION<br>MAKING</div></div>
                <div class="wf-arr">›</div>
                <div class="wf-step"><div class="wf-step-icon">🚀</div><div class="wf-step-lbl">ACTION<br>EXECUTE</div></div>
                <div class="wf-arr">›</div>
