(function(){
    const c=document.getElementById('donutCanvas'); if(!c) return;
    const cx=c.getContext('2d'),R=28,CX=36,CY=36;
    cx.beginPath(); cx.arc(CX,CY,R,0,Math.PI*2); cx.strokeStyle='rgba(255,255,255,.07)'; cx.lineWidth=8; cx.stroke();
    cx.beginPath(); cx.arc(CX,CY,R,-Math.PI/2,-Math.PI/2+Math.PI*2*.75);
    cx.strokeStyle='#00c8ff'; cx.lineWidth=8; cx.lineCap='round';
    cx.shadowColor='rgba(0,200,255,.5)'; cx.shadowBlur=8; cx.stroke(); cx.shadowBlur=0;
    cx.font='bold 10px "JetBrains Mono",monospace'; cx.textAlign='center'; cx.fillStyle='#00c8ff'; cx.fillText('75%',CX,CY+3.5);
})();

/* ── Data flow sparkline ── */
(function(){
    const c=document.getElementById('flowCanvas'); if(!c) return;
    const pw=c.parentElement.clientWidth-28; c.width=pw>20?pw:180;
    const cx=c.getContext('2d'),W=c.width,H=c.height;
    const pts=[.40,.58,.36,.72,.50,.66,.44,.78,.55,.62,.82,.67,.52];
    cx.fillStyle='rgba(0,10,30,.75)'; cx.fillRect(0,0,W,H);
    cx.strokeStyle='rgba(0,60,120,.28)'; cx.lineWidth=.5;
    for(let y=H/3;y<H;y+=H/3){cx.beginPath();cx.moveTo(0,y);cx.lineTo(W,y);cx.stroke();}
    cx.beginPath(); cx.moveTo(0,H);
    pts.forEach((v,i)=>{const x=(i/(pts.length-1))*W,y=H-v*(H-4)-2;cx.lineTo(x,y);});
    cx.lineTo(W,H); cx.closePath(); cx.fillStyle='rgba(0,150,255,.1)'; cx.fill();
    cx.beginPath();
    pts.forEach((v,i)=>{const x=(i/(pts.length-1))*W,y=H-v*(H-4)-2;i===0?cx.moveTo(x,y):cx.lineTo(x,y);});
    cx.strokeStyle='#00c8ff'; cx.lineWidth=1.5;
    cx.shadowColor='rgba(0,200,255,.5)'; cx.shadowBlur=5; cx.stroke(); cx.shadowBlur=0;
    pts.forEach((v,i)=>{const x=(i/(pts.length-1))*W,y=H-v*(H-4)-2;cx.beginPath();cx.arc(x,y,1.8,0,Math.PI*2);cx.fillStyle='#00c8ff';cx.fill();});
})();
</script>
