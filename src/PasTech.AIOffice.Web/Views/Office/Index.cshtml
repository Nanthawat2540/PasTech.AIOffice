        <!-- Metrics -->
        <div class="card">
            <div class="card-header">📊 Company Metrics</div>
            <div class="card-body">
                <div class="metrics-grid">
                    <div class="metric-box">
                        <div class="metric-val" style="color:#58a6ff" id="metricTasks">0</div>
                        <div class="metric-lbl">Tasks</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-val" style="color:#3fb950">7</div>
                        <div class="metric-lbl">Agents</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-val" style="color:#f0c040" id="metricPipeline">0</div>
                        <div class="metric-lbl">Pipeline ฿</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-val" style="color:#34d399">99.9%</div>
                        <div class="metric-lbl">Uptime</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Tasks -->
        <div class="card" style="flex:1">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
                <span>📋 Recent Tasks</span>
                <a href="/Dashboard" style="font-size:.72rem;color:#58a6ff;text-decoration:none">ดูทั้งหมด →</a>
            </div>
            <div class="card-body">
                <div class="task-ticker" id="taskTicker">
                    <div style="color:var(--muted);font-size:.8rem;text-align:center;padding:1rem">ยังไม่มีงาน</div>
                </div>
                <a href="/Dashboard/NewTask" class="btn-primary" style="display:block;text-align:center;text-decoration:none;margin-top:1rem;padding:.5rem;border-radius:6px;font-weight:700;font-size:.85rem">
                    + รับงานใหม่
                </a>
            </div>
        </div>

        <!-- System Bar -->
        <div class="system-bar">
            <div class="sys-item"><div class="sys-dot" style="background:#3fb950"></div> AI: claude-sonnet-4-6</div>
            <div class="sys-item"><div class="sys-dot" style="background:#58a6ff"></div> DB: SQL Server</div>
            <div class="sys-item"><div class="sys-dot" style="background:#f0c040"></div> ERP: Connected</div>
            <div class="sys-item" style="margin-left:auto" id="agentRunCount">Runs: 0</div>
        </div>

    </div><!-- /.sidebar -->
</div><!-- /.office-layout -->

<!-- ═══ AGENT MODAL ═══ -->
<div class="modal-overlay" id="agentModal" onclick="closeModal(event)">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div id="modalContent"></div>
    </div>
</div>

@section Scripts {
<script>
// ── Stars ──
(function(){
    const c = document.getElementById('stars');
    for (let i = 0; i < 90; i++) {
        const s = document.createElement('div');
        s.className = 'star';
        const sz = Math.random() * 2.5 + .4;
        s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-delay:${Math.random()*4}s;animation-duration:${2+Math.random()*3}s`;
        c.appendChild(s);
    }
})();

// ── Clock ──
function tick() {
    document.getElementById('clock').textContent =
        new Date().toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick, 1000);

// ── Agent Data ──
const agents = {
    ceo:       { name:'บอส (BOSS)',        title:'CEO / Orchestrator',         color:'#f0c040', emoji:'👑', dept:'Command Center',   hint:'มอบหมายงาน หรือถามภาพรวมบริษัท...', agentType: null },
    sales:     { name:'สมหมาย (Sommai)',   title:'Sales Manager',              color:'#60a5fa', emoji:'💼', dept:'Sales Office',      hint:'วางข้อความจากลูกค้าได้เลย เช่น: "สอบถามกล้องวงจรปิด..."', agentType: 1 },
    survey:    { name:'วิศว (Wit)',         title:'Senior Engineer',            color:'#22d3ee', emoji:'⚙️', dept:'Design Studio',     hint:'ระบุข้อมูลหน้างาน: พื้นที่, จำนวนจุด, ระบบที่ต้องการ...', agentType: 2 },
    quotation: { name:'นับทอง (Nab)',      title:'Quotation Specialist',       color:'#fbbf24', emoji:'💰', dept:'Finance Office',    hint:'วาง BOM จาก Survey Agent เพื่อทำใบเสนอราคา...', agentType: 3 },
    project:   { name:'ปิ่น (Pim)',        title:'Project Manager',            color:'#f87171', emoji:'📅', dept:'War Room',          hint:'วาง Quotation ที่อนุมัติแล้ว + วันเริ่มงาน...', agentType: 4 },
    document:  { name:'เอก (Ek)',          title:'Technical Writer',           color:'#34d399', emoji:'📄', dept:'Document Center',   hint:'ระบุรายการอุปกรณ์ที่ติดตั้งจริงเพื่อทำ As-Built...', agentType: 5 },
    support:   { name:'ช่วย (Chuai)',      title:'Support Engineer',           color:'#fb923c', emoji:'🛠️', dept:'Support Center',    hint:'บอกอาการที่ลูกค้าแจ้ง เช่น: "กล้องไม่ขึ้นภาพ..."', agentType: 6 },
    marketing: { name:'มายา (Maya)',       title:'Marketing Manager',          color:'#a78bfa', emoji:'📣', dept:'Creative Studio',   hint:'สรุปงานที่เสร็จแล้ว เช่น: "CCTV 28 จุด โรงงานชลบุรี"...', agentType: 7 },
};

function selectAgent(key, e) {
    document.querySelectorAll('.floor').forEach(f => f.classList.remove('active'));
    if (e && e.currentTarget) e.currentTarget.classList.add('active');
    const a = agents[key];
    moveElevator(key);
    document.getElementById('agentPanel').innerHTML = `
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
            <div style="width:48px;height:48px;border-radius:10px;background:${a.color}22;border:1px solid ${a.color}55;display:flex;align-items:center;justify-content:center;font-size:1.5rem">${a.emoji}</div>
            <div>
                <div style="font-weight:700;color:${a.color}">${a.name}</div>
                <div style="font-size:.72rem;color:var(--muted)">${a.title} · ${a.dept}</div>
            </div>
        </div>
        ${a.agentType ? `
        <form onsubmit="runAgent(event,'${key}')">
            <div style="margin-bottom:.75rem">
                <label style="font-size:.78rem;color:var(--muted);display:block;margin-bottom:.3rem">Input / คำสั่ง</label>
                <textarea name="input" rows="4" placeholder="${a.hint}" style="background:#060b14;border:1px solid #1e2d3d;color:#e6edf3;border-radius:6px;width:100%;padding:.5rem .75rem;font-size:.83rem;resize:vertical"></textarea>
            </div>
            <button type="submit" style="background:${a.color};border:none;color:#060b14;padding:.5rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;width:100%;font-size:.85rem">▶ Run ${a.name}</button>
        </form>
        ` : `<p style="color:var(--muted);font-size:.85rem;line-height:1.6">CEO คือ Orchestrator — ใช้ Dashboard เพื่อจัดการและมอบหมายงานทั้งหมด</p>
             <a href="/Dashboard" style="display:block;text-align:center;background:#f0c040;color:#060b14;padding:.5rem;border-radius:6px;font-weight:700;text-decoration:none;margin-top:.75rem">→ ไป Dashboard</a>`}
    `;
}

const floorMap = { ceo:4, marketing:36, support:108, document:180, project:252, quotation:324, survey:396, sales:468 };
function moveElevator(key) {
    const car = document.getElementById('elevatorCar');
    if (car) car.style.top = (floorMap[key] || 4) + 'px';
}

function openAgentModal(key) {
    const a = agents[key];
    document.getElementById('modalContent').innerHTML = `
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
            <div style="width:56px;height:56px;border-radius:12px;background:${a.color}22;border:2px solid ${a.color}55;display:flex;align-items:center;justify-content:center;font-size:2rem">${a.emoji}</div>
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:${a.color}">${a.name}</div>
                <div style="color:var(--muted);font-size:.8rem">${a.title} · ${a.dept}</div>
            </div>
        </div>
        ${a.agentType ? `
        <form onsubmit="runAgent(event,'${key}');closeModal()">
            <label style="font-size:.8rem;color:var(--muted);display:block;margin-bottom:.5rem">Input ถึง ${a.name}</label>
            <textarea name="input" rows="6" placeholder="${a.hint}" style="background:#060b14;border:1px solid #1e2d3d;color:#e6edf3;border-radius:6px;width:100%;padding:.75rem;font-size:.85rem;resize:vertical;margin-bottom:1rem"></textarea>
            <div style="display:flex;gap:.75rem">
                <button type="button" onclick="closeModal()" style="flex:1;background:transparent;border:1px solid #1e2d3d;color:var(--muted);padding:.6rem;border-radius:6px;cursor:pointer">ยกเลิก</button>
                <button type="submit" style="flex:2;background:${a.color};border:none;color:#060b14;padding:.6rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:.9rem">▶ Run Agent</button>
            </div>
        </form>
        ` : `<p style="color:var(--muted)">ใช้ Dashboard สำหรับ CEO Orchestrator</p>`}
    `;
    document.getElementById('agentModal').classList.add('open');
}

function closeModal(e) {
    if (!e || e.target === document.getElementById('agentModal'))
        document.getElementById('agentModal').classList.remove('open');
}

async function runAgent(e, key) {
    e.preventDefault();
    const dot = document.getElementById('dot-' + key);
    if (dot) dot.className = 'r-sdot working';
    const btn = e.target.querySelector('button[type=submit]');
    if (btn) { btn.disabled = true; btn.textContent = '⏳ กำลังทำงาน...'; }
    setTimeout(() => { window.location.href = '/Dashboard'; }, 600);
}
</script>
}
