function focusAgent(id){
    if(!AGENTS) return;
    const a = AGENTS.find(x=>x.id===id);
    if(a) showSel(a);
}
function showSel(a){
    const el=document.getElementById('rSelected'), cnt=document.getElementById('rSelectedContent');
    el.style.display='block';
    const sc={'THINKING':'#9333ea','DONE':'#22c55e','IDLE':'#6b7280'}[a.status]||'#6b7280';
    const info=AGENT_INFO[a.id]||{role:'AI Agent',domains:'—',channels:'—'};
    cnt.innerHTML=`<div class="r-agent-card">
        <div class="r-agent-nm">${a.name}</div>
        <div class="r-agent-rl">${info.role}</div>
        <div style="margin-top:5px;font-size:.55rem;color:#3a6080;font-family:var(--mono)">DOMAINS</div>
        <div style="font-size:.6rem;color:#88aac8;margin-bottom:4px">${info.domains}</div>
        <div style="font-size:.55rem;color:#3a6080;font-family:var(--mono)">CHANNELS</div>
        <div style="font-size:.6rem;color:#00c8ff;margin-bottom:6px">${info.channels}</div>
        <div style="font-size:.58rem;font-family:var(--mono);color:${sc};font-weight:700">● ${a.status}</div>
        <a class="r-agent-open" href="/Dashboard">OPEN WORKSPACE ›</a>
    </div>`;
}

